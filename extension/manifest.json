{
  "manifest_version": 3,
  "name": "Reway",
  "version": "0.1.0",
  "description": "Save pages to Reway and open bookmark groups.",
  "permissions": ["tabs", "activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://reway.page/*",
    "https://www.reway.page/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*"
  ],
  "action": {
    "default_title": "Save to Reway",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "open-quick-access": {
      "suggested_key": {
        "default": "Alt+Shift+R"
      },
      "description": "Open Reway quick access"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://reway.page/*",
        "https://www.reway.page/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["twitter-content-script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["access-content-script.bundle.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["access-content.css", "js/group-icon-manifest.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
